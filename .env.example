# LeadFlow AI - Environment Variables

# ============================================
# CLERK AUTHENTICATION
# Get these from: https://dashboard.clerk.com
# ============================================
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here

# ============================================
# CONVEX (Backend)
# Get these from: https://dashboard.convex.dev
# ============================================
VITE_CONVEX_URL=https://your-project.convex.cloud

# ============================================
# OPENAI (AI Message Generation)
# Get from: https://platform.openai.com/api-keys
# ============================================
OPENAI_API_KEY=sk-your_openai_key_here

# ============================================
# UNIPILE (LinkedIn Automation)
# Get from: https://www.unipile.com
# ============================================
VITE_UNIPILE_API_KEY=your_unipile_key_here
UNIPILE_DSN=your_unipile_dsn_here
UNIPILE_WEBHOOK_SECRET=your_webhook_secret_here

# ============================================
# GOOGLE SHEETS (Optional)
# For direct Google Sheets import
# ============================================
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

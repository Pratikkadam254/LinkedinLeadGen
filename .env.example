# Deployment
# The URL of your Convex deployment (automatically set by npx convex dev)
CONVEX_DEPLOYMENT=

# Public URL for Convex (automatically set by npx convex dev)
NEXT_PUBLIC_CONVEX_URL=

# Clerk Authentication
# Publishable key for Clerk (from Clerk Dashboard > API Keys)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
# Secret key for Clerk (from Clerk Dashboard > API Keys)
CLERK_SECRET_KEY=sk_test_...

# OpenAI (Message Generation)
# API key for generating personalized outreach messages (from platform.openai.com)
OPENAI_API_KEY=sk-...

# PhantomBuster (LinkedIn Scraping & Automation)
# API key to trigger Phantoms for scraping and connection requests
PHANTOMBUSTER_API_KEY=

# n8n Automation
# Webhook URL to trigger n8n workflows (e.g., for sending connection requests)
N8N_WEBHOOK_URL=https://n8n.your-domain.com/webhook/...

# Supabase (Optional - if using Option B from SOW)
# Project URL (from Supabase Dashboard > Settings > API)
NEXT_PUBLIC_SUPABASE_URL=
# Anon public key (from Supabase Dashboard > Settings > API)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Google Sheets (Optional - if using direct API access instead of n8n)
# Service account email
GOOGLE_SHEETS_CLIENT_EMAIL=
# Service account private key
GOOGLE_SHEETS_PRIVATE_KEY=

# LinkedIn Configuration
# Search URL for the specific Vistage persona (for reference or scraper input)
LINKEDIN_SALES_NAV_SEARCH_URL=https://www.linkedin.com/sales/search/people?savedSearchId=1954243172

# Project Config
# Environment (development, preview, production)
NODE_ENV=development

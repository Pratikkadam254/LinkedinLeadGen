# LeadFlow AI - Environment Variables

# ============================================
# FRONTEND (.env.local)
# ============================================

# Clerk Authentication
# Get from: https://dashboard.clerk.com → API Keys
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# Convex Backend
# Get from: https://dashboard.convex.dev → Settings
VITE_CONVEX_URL=https://your-project.convex.cloud

# ============================================
# BACKEND (Convex Dashboard → Settings → Environment Variables)
# These are NOT stored in .env files — set them in the Convex dashboard
# ============================================

# ANTHROPIC_API_KEY=sk-ant-...
# Get from: https://console.anthropic.com → API Keys

# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_PRO_PRICE_ID=price_...
# STRIPE_ELITE_PRICE_ID=price_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# Get from: https://dashboard.stripe.com

# UNIPILE_DSN=api1.unipile.com:13337
# UNIPILE_API_KEY=...
# Get from: https://dashboard.unipile.com

# APP_URL=http://localhost:5173
# Your app's public URL (used for Stripe/Unipile callbacks)
